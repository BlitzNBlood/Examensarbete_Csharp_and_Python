@using Microsoft.AspNetCore.Components.Forms
@using System.Diagnostics;
@page "/taxi"
@inject ApiService Api

<h3>Give taxi trip information</h3>

<EditForm Model="@model" OnValidSubmit="Submit">

    <InputNumber TValue="float?" @bind-Value="model.Trip_Distance_km" />
    <InputText @bind-Value="model.Time_of_Day" />
    <InputText @bind-Value="model.Day_of_Week" />
    <InputNumber TValue="float?" @bind-Value="model.Passenger_Count" />
    <InputText @bind-Value="model.Traffic_Conditions" />
    <InputText @bind-Value="model.Weather" />
    <InputNumber TValue="float?" @bind-Value="model.Base_Fare" />
    <InputNumber TValue="float?" @bind-Value="model.Per_Km_Rate" />
    <InputNumber TValue="float?" @bind-Value="model.Per_Minute_Rate" />
    <InputNumber TValue="float?" @bind-Value="model.Trip_Duration_Minutes" />

    <br />
    <button type="submit">PREDICT COST</button>

</EditForm>

@if (predictedCost != null)
{
    <h3>Predicted cost: @predictedCost</h3>
}

@code {
    private TaxiValues model = new();
    private double? predictedCost;

    private async Task Submit(EditContext context)
    {
        try
        {
            var timeFull = Stopwatch.StartNew();
            predictedCost = await Api.Predict(model);
            timeFull.Stop();
            Console.WriteLine($"Full operation time: {timeFull.ElapsedMilliseconds} ms");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }
}